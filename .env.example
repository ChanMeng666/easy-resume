# ===========================================
# Vitex - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# -------------------------------------------
# Neon Auth (Stack Auth)
# Stack Auth IS Neon Auth — Neon acquired Stack Auth, and the @stackframe/stack
# SDK is the (legacy) Neon Auth integration, fully supported. Enable Neon Auth
# in the Neon Console (Auth tab) or get keys from https://app.stack-auth.com/
# -------------------------------------------
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# -------------------------------------------
# Database (Neon PostgreSQL)
# Get connection string from https://neon.tech/
# -------------------------------------------
DATABASE_URL=

# -------------------------------------------
# OpenAI API (powers the AI generation pipeline)
# Get API key from https://platform.openai.com/
# -------------------------------------------
OPENAI_API_KEY=

# Model tiering (optional overrides). extract = cheap read/score steps
# (JD parse, ATS score); reason = quality-critical generation steps.
AI_MODEL_EXTRACT=gpt-4o-mini
AI_MODEL_REASON=gpt-4o

# -------------------------------------------
# AI observability (optional)
# When true, the AI SDK emits OpenTelemetry spans (e.g. for Langfuse).
# -------------------------------------------
AI_TELEMETRY_ENABLED=false
# Record raw prompt inputs/outputs (resume + JD = PII) on spans. OFF by default;
# only enable if your OTel collector is private and compliant. With it off, spans
# still carry timing/token/cost — just not the candidate's text.
AI_TELEMETRY_RECORD_IO=false

# Structured log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# -------------------------------------------
# Stripe (billing)
# Secret + webhook signing secret from https://dashboard.stripe.com/apikeys and
# the webhook endpoint settings. The three price IDs identify the credit pack and
# subscription products (server-side env, read by src/lib/stripe/checkout.ts).
# -------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREDITS_5=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_UNLIMITED_MONTHLY=

# -------------------------------------------
# Typst (PDF compilation) — usually only set in Docker
# TYPST_BIN is the typst binary path; TYPST_FONT_PATH points at the bundled
# FontAwesome webfonts. In dev these auto-detect from node_modules.
# -------------------------------------------
# TYPST_BIN=typst
# TYPST_FONT_PATH=/app/fonts

# -------------------------------------------
# Application URL
# -------------------------------------------
# Local development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production (update this to your deployed URL)
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# -------------------------------------------
# Object storage for compiled PDFs (Cloudflare R2 — OPTIONAL)
# When all four are set, compiled resume/cover-letter PDFs are persisted to R2
# and served from there; otherwise the PDF routes recompile from the stored
# Typst source on demand (<100ms). Create an R2 bucket + API token (Object Read
# & Write) at https://dash.cloudflare.com/ → R2.
# -------------------------------------------
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
